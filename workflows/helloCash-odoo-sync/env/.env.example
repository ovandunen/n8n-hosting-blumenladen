# HelloCash → Odoo sync — environment template (no secrets)
# Copy to env/.env.local or set the same keys in n8n / docker-compose.

# --- HelloCash ---
HELLOCASH_BASE_URL=https://api.hellocash.business
# HELLOCASH_API_TOKEN=   # set in n8n or env/.env.local

# --- Odoo JSON-RPC ---
ODOO_BASE_URL=http://host.docker.internal:8069
ODOO_DB=
ODOO_UID=
# ODOO_API_KEY=

# helloCash payment type routing
# HelloCash bulk invoices (GET /api/v1/invoices) expose invoice_payment as one of:
#   Bar | Bankomat | Kreditkarte | Kreditrechnung
# Map to Odoo picks journal + debit/credit accounts from the variables below. Unknown values log a warning and use Bar routing.
#
# Journal IDs: Odoo Settings → Technical → Journals (integer ID). Empty JOURNAL_* falls back to ODOO_JOURNAL_ID for that route.
JOURNAL_KASSE=        # Odoo journal ID, type: cash — used for Bar (and unknown payment fallback)
JOURNAL_BANK=         # Odoo journal ID, type: bank — Bankomat, Kreditkarte
JOURNAL_VERKAUF=      # Odoo journal ID, type: sale — Kreditrechnung

ODOO_JOURNAL_ID=      # Required fallback when a JOURNAL_* above is empty

# Account IDs: Odoo internal IDs (not SKR03 codes). Empty ACCOUNT_EC / ACCOUNT_KREDITKARTE / ACCOUNT_RECHNUNG fall back to ACCOUNT_BANK.
ACCOUNT_KASSE=1612    # SKR03 1610 — Bar debit (petty cash)
ACCOUNT_EC=1466       # SKR03 1206 — Bankomat debit
ACCOUNT_KREDITKARTE=1466  # SKR03 1206 — Kreditkarte debit
ACCOUNT_RECHNUNG=1464 # SKR03 1200 — Kreditrechnung debit (open receivable)
ACCOUNT_ERLOESE=1912  # SKR03 4400 — credit line (revenue, net) for all payment types above
ACCOUNT_UST_19=      # Required — Odoo USt 19 % (SKR03 e.g. 1776 / 3800); Map posts VAT as manual credit on this account when HelloCash taxes[].tax_net / tax_tax exist
ACCOUNT_UST_7=       # Optional — USt 7 % account; empty → same as ACCOUNT_UST_19

ACCOUNT_BANK=
ACCOUNT_GUTSCHEIN=

SYNC_HOUR=22
ERROR_EMAIL=
