# Copy to .env (same folder). Docker Compose reads .env for ${VAR} substitution.
# Or: docker compose --env-file env up -d

HELLOCASH_API_TOKEN=
HELLOCASH_BASE_URL=https://api.hellocash.business
HELLOCASH_LIST_PATH=/api/v1/cashBook
HELLOCASH_INVOICES_PATH=/api/v1/invoices

# Odoo: use host.docker.internal:8069 when Odoo runs on the Docker host (see docker-compose extra_hosts).
# Do not use http://localhost:8069 here — from inside the n8n container, localhost is not the host.
ODOO_BASE_URL=http://host.docker.internal:8069
ODOO_DB=your_database
ODOO_UID=2
ODOO_PASSWORD=
ODOO_JOURNAL_ID=1

ACCOUNT_KASSE=1000
ACCOUNT_BANK=1200
ACCOUNT_ERLOESE=8400
ACCOUNT_GUTSCHEIN=2800
TAX_ID_19=19
TAX_ID_7=7
SYNC_HOUR=22
ERROR_EMAIL=ops@example.com

N8N_USER=admin
N8N_PASSWORD=changeme
SMTP_USER=
SMTP_PASSWORD=
