# Copy to .env (same folder) or use: docker compose --env-file .env-blumenladen up -d
# Required variables use Docker Compose ${VAR:?…} — compose fails fast if unset.

# --- PostgreSQL (n8n database) ---
POSTGRES_USER=n8n
POSTGRES_DB=n8n
POSTGRES_PASSWORD=

# --- n8n core ---
# Generate once per deployment; changing it invalidates stored credentials.
N8N_ENCRYPTION_KEY=
N8N_USER=
N8N_PASSWORD=

# --- SMTP (n8n reads SMTP_*; port/SSL optional defaults 587 / false) ---
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=
N8N_SMTP_PORT=587
N8N_SMTP_SSL=false

# --- HelloCash ---
HELLOCASH_API_TOKEN=
HELLOCASH_BASE_URL=https://api.hellocash.business
HELLOCASH_LIST_PATH=/api/v1/cashBook
HELLOCASH_INVOICES_PATH=/api/v1/invoices
# true = ignore SYNC_HOUR gate (dev); false = production-style
HELLOCASH_IGNORE_SYNC_HOUR=false

# --- Odoo JSON-RPC (origin only, no /jsonrpc) ---
ODOO_BASE_URL=http://host.docker.internal:8069
ODOO_DB=
ODOO_UID=
ODOO_PASSWORD=
ODOO_JOURNAL_ID=

ACCOUNT_KASSE=
ACCOUNT_BANK=
ACCOUNT_ERLOESE=
ACCOUNT_GUTSCHEIN=
ACCOUNT_UST_19=
ACCOUNT_UST_7=
TAX_ID_19=
TAX_ID_7=

SYNC_HOUR=22
ERROR_EMAIL=

# Optional
TZ=UTC
N8N_API_KEY=
N8N_API_ENABLED=true
N8N_PUBLIC_API_DISABLED=false
